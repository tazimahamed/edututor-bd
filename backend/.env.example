# EduTutor BD — Environment Variables
# এই ফাইলটি কপি করে .env নামে সেভ করো

# ─── Google Gemini ──────────────────────────────────────────
# https://aistudio.google.com থেকে নাও
GEMINI_API_KEY=AIzaSy_YOUR_KEY_HERE
GEMINI_MODEL=gemini-1.5-flash

# ─── Supabase ───────────────────────────────────────────────
# https://supabase.com/dashboard থেকে নাও
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...YOUR_ANON_KEY
SUPABASE_SERVICE_KEY=eyJhbGci...YOUR_SERVICE_KEY

# ─── ChromaDB ───────────────────────────────────────────────
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION=nctb_textbooks

# ─── Security ───────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key-in-production
